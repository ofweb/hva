declare -A _pi_lens_roots_seen=()
PI_LENS_VOLUME_MOUNTS=()
PI_LENS_WORKSPACE_DIRS=()  # host-side dirs Docker creates as mount scaffolding — deleted after container starts

add_pi_lens_volume_mount() {
  local root="$1"
  local rel_path container_path state_path

  root="$(realpath "$root")"
  if [[ -z "${_pi_lens_roots_seen[$root]+x}" ]]; then
    _pi_lens_roots_seen["$root"]=1
    if [[ "$root" == "$WORKSPACE" ]]; then
      state_path="$WORKSPACE_STATE_ROOT/pi-lens"
      container_path="/workspace/.pi-lens"
    else
      rel_path="${root#"$WORKSPACE"/}"
      state_path="$WORKSPACE_STATE_ROOT/pi-lens-subs/$rel_path"
      container_path="/workspace/$rel_path/.pi-lens"
    fi
    mkdir -p "$state_path"
    PI_LENS_VOLUME_MOUNTS+=("$state_path:$container_path")
    if [[ ! -e "$root/.pi-lens" ]]; then
      PI_LENS_WORKSPACE_DIRS+=("$root/.pi-lens")
    else
      _pi_lens_preexisting["$root/.pi-lens"]=1
    fi
  fi
}

# Remove empty .pi-lens scaffold dirs Docker creates on the host as mount points.
# The volume mount still works inside the container — only the host-side artifact is removed.
remove_pi_lens_host_artifacts() {
  local lens_dir
  for lens_dir in "${PI_LENS_WORKSPACE_DIRS[@]:-}"; do
    rmdir "$lens_dir" 2>/dev/null || true
  done
}

add_pi_lens_volume_mount "$WORKSPACE"
while IFS= read -r -d '' manifest_path; do
  add_pi_lens_volume_mount "$(dirname "$manifest_path")"
done < <(
  find "$WORKSPACE" \
    \( -name .git -o -name node_modules -o -name target -o -name .hva-state \
       -o -name dist -o -name build -o -name out -o -name .next \
       -o -name __pycache__ -o -name .venv -o -name venv -o -name .turbo \) -prune -o \
    \( -name package.json -o -name Cargo.toml -o -name pyproject.toml -o -name go.mod -o -name Gemfile -o -name composer.json -o -name pom.xml -o -name build.gradle -o -name build.gradle.kts \) \
    -print0 2>/dev/null
)

