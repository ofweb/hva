add_required_container_env() {
  local env_name="$1"
  if [[ -z "${!env_name+x}" ]]; then
    echo "required container env missing: $env_name" >&2
    exit 1
  fi
  start_docker_args+=(-e "${env_name}=${!env_name}")
  exec_args+=(-e "${env_name}=${!env_name}")
}

add_optional_container_env() {
  local env_name="$1"
  if [[ -n "${!env_name-}" ]]; then
    start_docker_args+=(-e "${env_name}=${!env_name}")
    exec_args+=(-e "${env_name}=${!env_name}")
  fi
}

for env_name in \
  HVA_MCP_ENABLED \
  HVA_MCP_DISABLED \
  HVA_SKILLS_ENABLED \
  HVA_SKILLS_DISABLED \
  SEARXNG_URL \
  HVA_MOUNT_GIT \
  LLAMA_CONTEXT_SIZE; do
  add_required_container_env "$env_name"
done

for env_name in \
  GITHUB_PERSONAL_ACCESS_TOKEN \
  GITHUB_TOKEN \
  BRAVE_API_KEY; do
  if [[ -n "${!env_name-}" ]] && should_pass_secret_env "$env_name"; then
    add_optional_container_env "$env_name"
  fi
done

if [[ "${HVA_UNSAFE:-0}" == "1" ]]; then
  start_docker_args+=(
    --cap-add SYS_PTRACE
    --security-opt seccomp=unconfined
  )
fi

if [[ -S /var/run/docker.sock ]]; then
  docker_sock_gid="$(stat -c '%g' /var/run/docker.sock)"
  if [[ "${HVA_MOUNT_DOCKER_SOCKET:-0}" == "1" ]]; then
    start_docker_args+=(
      -v /var/run/docker.sock:/var/run/docker.sock
      --group-add "$docker_sock_gid"
    )
  fi
fi

if [[ "${HVA_MOUNT_GITCONFIG:-0}" == "1" && -f "$HOME/.gitconfig" ]]; then
  start_docker_args+=(-v "$HOME/.gitconfig:/home/$DEV_USER/.gitconfig:ro")
fi

if [[ "${HVA_MOUNT_NVIM:-0}" == "1" && -d "$HOME/.config/nvim" ]]; then
  start_docker_args+=(-v "$HOME/.config/nvim:/home/$DEV_USER/.config/nvim:ro")
fi

if [[ "${HVA_MOUNT_SSH:-0}" == "1" && -d "$HOME/.ssh" ]]; then
  start_docker_args+=(-v "$HOME/.ssh:/home/$DEV_USER/.ssh:ro")
fi

if [[ "${HVA_MOUNT_GIT:-0}" != "1" ]]; then
  while IFS= read -r -d '' git_path; do
    rel_path="${git_path#"$WORKSPACE"/}"
    if [[ "$git_path" == "$WORKSPACE" ]]; then
      rel_path="."
    fi
    dest="/workspace/$rel_path"

    if [[ -d "$git_path" ]]; then
      start_docker_args+=(--tmpfs "$dest:rw,noexec,nosuid,nodev,size=64k")
    elif [[ -f "$git_path" ]]; then
      start_docker_args+=(--mount "type=bind,source=$GIT_FILE_MASK,target=$dest,readonly")
    fi
  done < <(find "$WORKSPACE" -name .git -prune -print0 2>/dev/null)
fi

