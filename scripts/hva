hva_ensure_pi_extension_deps
/hva/internals/pi-loop.sh
'
  else
    case "$HVA_MODE" in
      bash)
        set -- bash
        ;;
      pi)
        if [[ -n "$PROMPT_HOST_FILE" ]]; then
          set -- bash -lc '
source /hva/internals/pi-runtime.sh
hva_ensure_pi_extension_deps
session_dir="/hva-state/pi-sessions"
session_mode="$1"
prompt_text="$(cat "$2")"
run_args=()
if [[ "$session_mode" == "continue" ]]; then
  run_args+=(--continue)
fi
HVA_PI_SESSION_DIR="$session_dir" hva_run_pi "" "${run_args[@]}" --print "$prompt_text"
' bash "$PI_SESSION_MODE" "$PROMPT_CONTAINER_FILE"
        else
          set -- bash -lc '
source /hva/internals/pi-runtime.sh
hva_ensure_pi_extension_deps
session_dir="/hva-state/pi-sessions"
session_mode="$1"
run_args=()
if [[ "$session_mode" == "continue" ]]; then
  run_args+=(--continue)
fi
HVA_PI_SESSION_DIR="$session_dir" hva_run_pi "" "${run_args[@]}"
' bash "$PI_SESSION_MODE"
        fi
        ;;
      *)
        echo "unknown HVA_MODE: $HVA_MODE" >&2
        exit 1
        ;;
    esac
  fi
fi

if [[ "$MODE" != "prompt" ]]; then
  echo "workspace: $WORKSPACE ($LLAMA_MODEL_ALIAS · $LLAMA_MODEL)"
