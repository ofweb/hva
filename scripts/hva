#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"
HVA_ROOT="${HVA_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd -P)}"

usage() {
  cat <<EOF
Usage:
  hva                          start/reuse llama, enter workspace, open Pi
  hva --local                  start/reuse llama, then open host Pi
  hva --bash                   shell into running dev container, or start one if needed
  hva --new                    start a fresh Pi session (clears resume state)
  hva --new-hard               start a fresh Pi session and recreate the dev container
  hva --msg TEXT               one-shot Pi message
  hva --prompt TEXT            one-shot Pi prompt (alias for --msg)
  hva --prompt-file FILE       one-shot Pi prompt from file
  hva --diff-review REV        review git diff from REV..HEAD

  hva --diff-review-branch BRANCH
                               review git diff from merge-base(BRANCH, HEAD)..HEAD

  hva --diff-review-main       review git diff from merge-base(main/master, HEAD)..HEAD
  hva --diff-review-staged     review staged git diff
  hva --diff-review-unstaged   review unstaged git diff
  hva --diff-review-all        review tracked + untracked git diff without touching real index

  hva --stop                   stop llama, searxng, and dev container
  hva --start-searxng          start SearXNG helper container
  hva --stop-searxng           stop SearXNG helper container
  hva --update                 pull latest hva, ensure config exists, refresh Pi config
  hva --reset-pi-cache         clear cached Pi config/home (rebuilt on next run)
  hva --cleanup-docker [--apply] [--volumes] [--global-build-cache]
                               show Docker storage; prune HVA-owned leftovers when applied
  hva --runtime-state [WORKSPACE]
                               print HVA state paths for this workspace
  hva --daemon                 start llama server as background daemon
  hva --healthcheck            compact llama health verdict; strict on cache invalidation
  hva --llama-cpp-update       update pinned llama.cpp image digest, then pull it
  hva --llama-cpp-logs-full    print full llama server container logs
  hva --build-docker-prison    build dev image if missing/outdated (--force to rebuild anyway)
  hva --check-versions         check pinned vs latest upstream versions
  hva --loop [WORKSPACE]       run Pi loop mode using WORKSPACE/tasks.md
  hva --loop-init [WORKSPACE]  create a tasks.md template in workspace root
  hva --loop-stop [WORKSPACE]  ask a running loop to stop after this iteration
  hva --loop-status [WORKSPACE]
                               print current loop status from workspace state
EOF
}

MODE="start"
PROMPT_TEXT=""
PROMPT_FILE=""
DIFF_REVIEW_MODE=""
DIFF_REVIEW_TARGET=""
USE_LOCAL_PI=0

while [[ $# -gt 0 ]]; do
  case "${1:-}" in
    --new)
      HVA_NEW_SESSION=1
      shift
      ;;
    --new-hard)
      HVA_NEW_SESSION=1
      HVA_NEW_HARD_SESSION=1
      shift
      ;;
    --local|--host-pi)
      USE_LOCAL_PI=1
      shift
      ;;
    *)
      break
      ;;
  esac
done

case "${1:-}" in
  --stop|-stop) MODE="stop"; shift ;;
  --loop) MODE="loop"; shift ;;
  --loop-init) MODE="loop-init"; shift ;;
  --loop-stop) MODE="loop-stop"; shift ;;
  --loop-status) MODE="loop-status"; shift ;;
  --start-searxng) MODE="start-searxng"; shift ;;
  --stop-searxng) MODE="stop-searxng"; shift ;;
  --update) exec "$HVA_ROOT/internals/update.sh" ;;
  --reset-pi-cache) MODE="reset-pi-cache"; shift ;;
  --cleanup-docker) exec "$HVA_ROOT/internals/cleanup-docker.sh" "${@:2}" ;;
  --runtime-state) MODE="runtime-state"; shift ;;
  --daemon) MODE="daemon"; shift ;;
  --bash) MODE="bash"; shift ;;
  --msg|--prompt)
    [[ $# -ge 2 ]] || { echo "$1 requires text" >&2; exit 1; }
    MODE="prompt"
    PROMPT_TEXT="$2"
    shift 2
    ;;
  --prompt-file)
    [[ $# -ge 2 ]] || { echo "--prompt-file requires a file path" >&2; exit 1; }
    MODE="prompt"
    PROMPT_FILE="$2"
    shift 2
    ;;
  --diff-review)
    [[ $# -ge 2 ]] || { echo "--diff-review requires a revision" >&2; exit 1; }
    MODE="diff-review"
    DIFF_REVIEW_MODE="commit"
    DIFF_REVIEW_TARGET="$2"
    shift 2
    ;;
  --diff-review-branch)
    [[ $# -ge 2 ]] || { echo "--diff-review-branch requires a branch or revision" >&2; exit 1; }
    MODE="diff-review"
    DIFF_REVIEW_MODE="branch"
    DIFF_REVIEW_TARGET="$2"
    shift 2
    ;;
  --diff-review-main)
    MODE="diff-review"
    DIFF_REVIEW_MODE="main"
    shift
    ;;
  --diff-review-staged)
    MODE="diff-review"
    DIFF_REVIEW_MODE="staged"
    shift
    ;;
  --diff-review-unstaged)
    MODE="diff-review"
    DIFF_REVIEW_MODE="unstaged"
    shift
    ;;
  --diff-review-all)
    MODE="diff-review"
    DIFF_REVIEW_MODE="all"
    shift
    ;;
  --healthcheck) exec "$HVA_ROOT/internals/healthcheck.sh" "${@:2}" ;;
  --llama-cpp-update) exec "$HVA_ROOT/internals/llama-cpp-update.sh" "${@:2}" ;;
  --build-docker-prison) exec "$HVA_ROOT/internals/build-docker-prison.sh" "${@:2}" ;;
  --check-versions) exec "$HVA_ROOT/internals/check-versions.sh" "${@:2}" ;;
  --llama-cpp-logs-full) exec "$HVA_ROOT/internals/run-hva-llama-cpp.sh" logs ;;
  -h|--help|help) usage; exit 0 ;;
  --*)
    echo "unknown option: $1" >&2
    usage
    exit 1
    ;;
  -*)
    echo "unknown option: $1" >&2
    usage
    exit 1
    ;;
esac

if (( USE_LOCAL_PI == 1 )); then
  case "$MODE" in
    start|prompt|diff-review) ;;
    *)
      echo "--local only supports interactive Pi, --msg/--prompt-file, and diff review." >&2
      exit 1
      ;;
  esac
fi

if [[ "$MODE" == "reset-pi-cache" ]]; then
  rm -rf "$HVA_ROOT/.hva-state/pi-home"
  echo "pi cache cleared — fresh config will be written on next: hva"
  exit 0
fi

case "$MODE" in
  stop)
    source "$SCRIPT_DIR/../internals/docker.sh"
    "$HVA_ROOT/internals/run-hva-llama-cpp.sh" stop
    "$HVA_ROOT/internals/run-hva-searxng.sh" stop
    "${DOCKER[@]}" rm -f hva-dev >/dev/null 2>&1 || true
    exit 0
    ;;
  start-searxng)
    exec "$HVA_ROOT/internals/run-hva-searxng.sh" start
    ;;
  stop-searxng)
    exec "$HVA_ROOT/internals/run-hva-searxng.sh" stop
    ;;
esac

DEV_IMAGE="hva-safeprison"
DEV_USER="dev"
HVA_MODE="pi"
PROMPT_HOST_FILE=""
PROMPT_CONTAINER_FILE="/hva-state/hva-prompt-$$.txt"
PROMPT_FILE_TEMP=0

if (( USE_LOCAL_PI == 1 )); then
  HVA_MODE="local-pi"
fi

if [[ "$MODE" == "bash" ]]; then
  HVA_MODE="bash"
  HVA_WAIT_LLAMA="${HVA_WAIT_LLAMA:-0}"
fi

WORKSPACE="$PWD"
if [[ $# -gt 0 && -d "$1" ]]; then
  WORKSPACE="$1"
  shift
fi
WORKSPACE="$(realpath "$WORKSPACE")"
HVA_STATE_ROOT="$HVA_ROOT/.hva-state"

workspace_base="$(basename "$WORKSPACE")"
safe_workspace_name="$(printf '%s' "$workspace_base" | tr -c 'A-Za-z0-9_.-' '-')"
if [[ -z "$safe_workspace_name" ]]; then
  safe_workspace_name="workspace"
fi
workspace_hash="$(printf '%s' "$WORKSPACE" | sha256sum | cut -c1-12)"

if [[ ! -d "$WORKSPACE" ]]; then
  echo "workspace does not exist: $WORKSPACE" >&2
  exit 1
fi

case "$WORKSPACE" in
  /tmp|/var/tmp|/dev/shm)
    if [[ "${HVA_ALLOW_SYSTEM_TMP_WORKSPACE:-0}" != "1" ]]; then
      echo "refusing to use system temp root as workspace: $WORKSPACE" >&2
      echo "cd into a project directory, pass one explicitly, or set HVA_ALLOW_SYSTEM_TMP_WORKSPACE=1." >&2
      exit 1
    fi
    ;;
esac

if [[ "$MODE" == "loop" || "$MODE" == "loop-init" || "$MODE" == "loop-stop" || "$MODE" == "loop-status" || "$MODE" == "runtime-state" ]]; then
  if [[ $# -gt 0 ]]; then
    echo "unexpected argument for $MODE: $1" >&2
    usage >&2
    exit 1
  fi
fi

LOOP_TASK_FILE="$WORKSPACE/tasks.md"
LOOP_STATE_DIR="$HVA_STATE_ROOT/workspaces/$safe_workspace_name-$workspace_hash/loop"
WORKSPACE_STATE_ROOT="$HVA_STATE_ROOT/workspaces/$safe_workspace_name-$workspace_hash"

create_loop_tasks_file() {
  local template="$HVA_ROOT/pi/tasks-template.md"

  if [[ ! -f "$template" ]]; then
    echo "tasks template missing: $template" >&2
    exit 1
  fi

  if [[ -e "$LOOP_TASK_FILE" ]]; then
    echo "tasks.md already exists: $LOOP_TASK_FILE"
    return
  fi

  install -D -m 0644 "$template" "$LOOP_TASK_FILE"
  echo "created: $LOOP_TASK_FILE"
}

ensure_workspace_state_mount_target() {
  mkdir -p "$WORKSPACE_STATE_ROOT"
}

print_loop_status() {
  local status_file="$LOOP_STATE_DIR/status"
  local stop_file="$LOOP_STATE_DIR/stop"
  local loop_log="$LOOP_STATE_DIR/loop.log"

  if [[ ! -f "$status_file" ]]; then
    if [[ -f "$stop_file" ]]; then
      echo "state: stop_requested"
    else
      echo "state: idle (no loop running for this workspace)"
    fi
    echo "workspace: $WORKSPACE"
    echo "task_file: $LOOP_TASK_FILE"
    if [[ -f "$loop_log" ]]; then
      echo "last_log: $loop_log"
    fi
    return 0
  fi

  local _read_field
  _read_field() { grep "^${1}:" "$status_file" 2>/dev/null | sed "s/^${1}:[[:space:]]*//" | head -1; }

  local state phase iteration target pending done_count blocked elapsed msg
  state="$(_read_field state)"
  phase="$(_read_field phase)"
  iteration="$(_read_field iteration)"
  target="$(_read_field current_target)"
  pending="$(_read_field pending_tasks)"
  done_count="$(_read_field done_tasks)"
  blocked="$(_read_field blocked_tasks)"
  elapsed="$(_read_field elapsed_seconds)"
  msg="$(_read_field message)"

  local elapsed_fmt
  elapsed_fmt="$(printf '%dm%ds' "$(( ${elapsed:-0} / 60 ))" "$(( ${elapsed:-0} % 60 ))")"

  echo "state:      $state"
  echo "phase:      $phase"
  echo "iteration:  $iteration  (${elapsed_fmt} elapsed)"
  echo "tasks:      done=${done_count:-0}  pending=${pending:-0}  blocked=${blocked:-0}"
  [[ -n "$target" ]] && echo "current:    $target"
  [[ -n "$msg" ]]    && echo "message:    $msg"
  echo "task_file:  $LOOP_TASK_FILE"
  echo "log:        $loop_log"
}

print_runtime_state() {
  echo "hva_root: $HVA_ROOT"
  echo "workspace: $WORKSPACE"
  echo "workspace_state: $WORKSPACE_STATE_ROOT"
  echo "session_dir: $WORKSPACE_STATE_ROOT/pi-sessions"
  echo "session_resume: pi --continue via session_dir"
  echo "loop_state: $LOOP_STATE_DIR"
  echo "pi_home_cache: $HVA_STATE_ROOT/pi-home"
  echo "pi_extension_node_modules: $HVA_STATE_ROOT/pi-extension-node_modules"
  echo "target_project_state: none"
}

case "$MODE" in
  runtime-state)
    print_runtime_state
    exit 0
    ;;
  loop-init)
    # shellcheck disable=SC1091
    source "$HVA_ROOT/internals/load-config.sh"
    create_loop_tasks_file
    exit 0
    ;;
  loop-stop)
    mkdir -p "$LOOP_STATE_DIR"
    : > "$LOOP_STATE_DIR/stop"
    echo "loop stop requested: $LOOP_STATE_DIR/stop"
    exit 0
    ;;
  loop-status)
    print_loop_status
    exit 0
    ;;
  loop)
    if [[ ! -f "$LOOP_TASK_FILE" ]]; then
      echo "tasks.md not found in workspace: $LOOP_TASK_FILE" >&2
      echo "Create one with: hva --loop-init" >&2
      exit 1
    fi
    ;;
esac

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../internals/docker.sh"

if [[ "$MODE" == "stop" ]]; then
  "$HVA_ROOT/internals/run-hva-llama-cpp.sh" stop
  "$HVA_ROOT/internals/run-hva-searxng.sh" stop
  "${DOCKER[@]}" rm -f hva-dev >/dev/null 2>&1 || true
  exit 0
fi

if [[ "$MODE" == "start-searxng" ]]; then
  exec "$HVA_ROOT/internals/run-hva-searxng.sh" start
fi

if [[ "$MODE" == "stop-searxng" ]]; then
  exec "$HVA_ROOT/internals/run-hva-searxng.sh" stop
fi

# shellcheck disable=SC1091
source "$HVA_ROOT/internals/load-config.sh"
mkdir -p "$LLAMA_MODELS"
env_validate_required
hva_load_secrets
hva_normalize_github_tokens

csv_has_value() {
  local needle="$1"
  local csv="${2:-}"
  local item

  IFS=',' read -r -a _csv_items <<< "$csv"
  for item in "${_csv_items[@]}"; do
    item="${item#"${item%%[![:space:]]*}"}"
    item="${item%"${item##*[![:space:]]}"}"
    if [[ "$item" == "$needle" ]]; then
      return 0
    fi
  done

  return 1
}

hva_mcp_enabled() {
  local name="$1"

  if [[ -n "${HVA_MCP_ENABLED:-}" || -n "${HVA_MCP_DISABLED:-}" ]]; then
    csv_has_value "$name" "${HVA_MCP_ENABLED:-}" && ! csv_has_value "$name" "${HVA_MCP_DISABLED:-}"
    return
  fi

  return 1
}

should_pass_secret_env() {
  local env_name="$1"

  case "$env_name" in
    GITHUB_PERSONAL_ACCESS_TOKEN|GITHUB_TOKEN)
      hva_mcp_enabled "github" || hva_mcp_enabled "rust-docs"
      ;;
    BRAVE_API_KEY)
      ! hva_mcp_enabled "searxng" && hva_mcp_enabled "brave-search"
      ;;
    *)
      return 1
      ;;
  esac
}

if [[ "$MODE" == "daemon" ]]; then
  exec "$HVA_ROOT/internals/run-hva-llama-cpp.sh" daemon
fi

cleanup() {
  if [[ "$PROMPT_FILE_TEMP" == "1" && -n "$PROMPT_HOST_FILE" && -f "$PROMPT_HOST_FILE" ]]; then
    rm -f "$PROMPT_HOST_FILE"
  fi

  for lens_link in "${PI_LENS_LOCAL_SYMLINKS[@]:-}"; do
    if [[ -L "$lens_link" ]]; then
      rm -f "$lens_link"
    fi
  done

  if declare -F remove_pi_lens_host_artifacts >/dev/null 2>&1; then
    remove_pi_lens_host_artifacts
  fi

  # Remove any .pi-lens dirs written directly into the workspace during the session
  # (dirs created at runtime won't have a volume mount, so pi-lens writes there directly)
  local _cleanup_lens_dir
  while IFS= read -r -d '' _cleanup_lens_dir; do
    if [[ -z "${_pi_lens_preexisting["$_cleanup_lens_dir"]+x}" ]]; then
      rm -rf "$_cleanup_lens_dir"
    fi
  done < <(find "$WORKSPACE" \
    \( -name .git -o -name node_modules -o -name target -o -name .hva-state \
       -o -name dist -o -name build -o -name out -o -name .next \
       -o -name __pycache__ -o -name .venv -o -name venv -o -name .turbo \) -prune -o \
    -type d -name '.pi-lens' -print0 2>/dev/null)
}

trap cleanup EXIT

write_prompt_text_file() {
  local text="$1"
  mkdir -p "$WORKSPACE_STATE_ROOT"
  PROMPT_HOST_FILE="$WORKSPACE_STATE_ROOT/hva-prompt-$$.txt"
  PROMPT_FILE_TEMP=1
  printf '%s' "$text" > "$PROMPT_HOST_FILE"
}

validate_diff_review_size() {
  local label="$1"
  local diff_content="$2"
  local diff_bytes diff_lines max_bytes

  diff_bytes="$(printf '%s' "$diff_content" | wc -c | tr -d ' ')"
  diff_lines="$(printf '%s' "$diff_content" | wc -l | tr -d ' ')"
  max_bytes=$((LLAMA_CONTEXT_SIZE * 3))

  if (( diff_bytes > max_bytes )); then
    echo "diff too large for review: $label" >&2
    echo "diff bytes: $diff_bytes" >&2
    echo "diff lines: $diff_lines" >&2
    echo "soft limit from LLAMA_CONTEXT_SIZE=$LLAMA_CONTEXT_SIZE: $max_bytes bytes" >&2
    echo "try a narrower diff review target" >&2
    echo "  hva --diff-review-staged" >&2
    echo "  hva --diff-review-unstaged" >&2
    echo "  hva --diff-review <rev>" >&2
    echo "  hva --diff-review-branch <branch>" >&2
    exit 1
  fi
}

prepare_diff_review_prompt() {
  local diff_content label

  case "$DIFF_REVIEW_MODE" in
    unstaged) label="unstaged changes" ;;
    staged) label="staged changes" ;;
    commit) label="diff from $DIFF_REVIEW_TARGET to HEAD" ;;
    branch) label="diff from merge-base($DIFF_REVIEW_TARGET, HEAD) to HEAD" ;;
    main) label="diff from merge-base(main/master, HEAD) to HEAD" ;;
    all) label="all changes" ;;
    *) echo "unknown diff review mode: $DIFF_REVIEW_MODE" >&2; exit 1 ;;
  esac

  diff_content="$("$HVA_ROOT/internals/git-diff.sh" "$DIFF_REVIEW_MODE" "$DIFF_REVIEW_TARGET" "$WORKSPACE")"

  if [[ -z "$diff_content" ]]; then
    echo "no $label"
    exit 0
  fi

  validate_diff_review_size "$label" "$diff_content"

  mkdir -p "$WORKSPACE_STATE_ROOT"
  PROMPT_HOST_FILE="$WORKSPACE_STATE_ROOT/hva-prompt-$$.txt"
  PROMPT_FILE_TEMP=1
  {
    cat "$HVA_ROOT/hva-runtime/diff-review.md"
    printf '\n\nReview target: %s\n\nDiff:\n' "$label"
    printf '```diff\n'
    printf '%s\n' "$diff_content"
    printf '```\n'
  } > "$PROMPT_HOST_FILE"
}

prepare_prompt_mode() {
  case "$MODE" in
    prompt)
      if [[ -n "$PROMPT_FILE" ]]; then
        if [[ ! -f "$PROMPT_FILE" ]]; then
          echo "prompt file does not exist: $PROMPT_FILE" >&2
          exit 1
        fi
        mkdir -p "$WORKSPACE_STATE_ROOT"
        PROMPT_HOST_FILE="$WORKSPACE_STATE_ROOT/hva-prompt-$$.txt"
        PROMPT_FILE_TEMP=1
        cp "$(realpath "$PROMPT_FILE")" "$PROMPT_HOST_FILE"
      else
        write_prompt_text_file "$PROMPT_TEXT"
      fi
      ;;
    diff-review)
      prepare_diff_review_prompt
      ;;
    *)
      return
      ;;
  esac
}

prepare_prompt_mode

source "$SCRIPT_DIR/../internals/docker-network.sh"

REQUESTED_DOCKER_NETWORK="$(hva_requested_docker_network)"
FORCED_DOCKER_NETWORK_MODE="${HVA_DOCKER_NETWORK_MODE:-}"
HVA_DOCKER_NETWORK_MODE="$(hva_detect_docker_network_mode)"

if [[ -z "$FORCED_DOCKER_NETWORK_MODE" && "$REQUESTED_DOCKER_NETWORK" != "host" && "$REQUESTED_DOCKER_NETWORK" != "none" && "$HVA_DOCKER_NETWORK_MODE" == "host" ]]; then
  echo "could not use \"$REQUESTED_DOCKER_NETWORK\"; using host mode" >&2
fi

if [[ "$HVA_MODE" == "local-pi" ]]; then
  if [[ -z "${SEARXNG_URL:-}" || "${SEARXNG_URL:-}" == "http://host.docker.internal:8888" ]]; then
    export SEARXNG_URL
    SEARXNG_URL="http://127.0.0.1:${SEARXNG_HOST_PORT:-8888}"
  fi
elif [[ -z "${SEARXNG_URL:-}" || "${SEARXNG_URL:-}" == "http://host.docker.internal:8888" ]]; then
  export SEARXNG_URL
  SEARXNG_URL="$(hva_searxng_url_for_network "$HVA_DOCKER_NETWORK_MODE" "${SEARXNG_HOST_PORT:-8888}")"
fi

ensure_llama_server() {
  if [[ "${HVA_SKIP_LLAMA:-0}" == "1" ]]; then
    echo "skipping llama server startup because HVA_SKIP_LLAMA=1"
    return
  fi

  local action="daemon"
  if [[ "${HVA_RESTART_LLAMA:-0}" == "1" ]]; then
    action="restart"
  fi

  "$HVA_ROOT/internals/run-hva-llama-cpp.sh" "$action" >/dev/null
}

print_llama_startup_failure() {
  local url="$1"
  local timeout="$2"

  {
    echo
    echo "llama server did not become ready within ${timeout}s."
    echo "URL: $url"
    echo "Container: $LLAMA_CONTAINER"
    echo
    echo "Full llama logs:"
  } >&2

  if ! "${DOCKER[@]}" logs "$LLAMA_CONTAINER" >&2; then
    echo "could not read logs for container: $LLAMA_CONTAINER" >&2
  fi

  {
    echo
    echo "FAILED LOADING LLAMA.CPP"
    echo
    echo "Try:"
    echo "  $HVA_ROOT/internals/run-hva-llama-cpp.sh status"
    echo "  ${DOCKER[*]} logs -f $LLAMA_CONTAINER"
    echo "  hva --stop"
  } >&2
}

wait_for_llama_server() {
  if [[ "${HVA_SKIP_LLAMA:-0}" == "1" ]]; then
    return
  fi

  if [[ "${HVA_WAIT_LLAMA:-1}" == "0" ]]; then
    return
  fi

  local url="http://127.0.0.1:$LLAMA_HOST_PORT/v1/models"
  local timeout="${HVA_LLAMA_WAIT_TIMEOUT:-40}"
  local waited=0

  if ! command -v curl >/dev/null 2>&1; then
    echo "curl is not installed; skipping llama readiness check" >&2
    return
  fi

  local first_check=1
  until curl -fsS --max-time 2 "$url" >/dev/null 2>&1; do
    if (( first_check == 1 )); then
      echo "waiting for llama server..."
      first_check=0
    fi
    if (( waited >= timeout )); then
      print_llama_startup_failure "$url" "$timeout"
      exit 1
    fi
    sleep 2
    waited=$((waited + 2))
  done
}

ensure_dev_image() {
  IMAGE_NAME="$DEV_IMAGE" "$HVA_ROOT/internals/build-docker-prison.sh"
}

dev_container_is_reusable() {
  local cws
  if ! "${DOCKER[@]}" ps -q --filter "name=^${dev_name}$" | grep -q .; then
    return 1
  fi

  # Verify writable bind-mounts are still usable. A state/cache nuke can leave
  # the container holding nlink=0 (orphaned) inodes that reject new writes.
  if ! "${DOCKER[@]}" exec "$dev_name" bash -c \
       'touch /hva/pi/extensions/.reuse-check 2>/dev/null &&
        rm -f /hva/pi/extensions/.reuse-check &&
        mkdir -p /hva-state/.reuse-check 2>/dev/null &&
        rmdir /hva-state/.reuse-check' \
       2>/dev/null; then
    return 1
  fi

  cws="$("${DOCKER[@]}" inspect "$dev_name" --format '{{ index .Config.Labels "dev.hva.workspace" }}' 2>/dev/null || true)"
  [[ "$cws" == "$WORKSPACE" ]]
}

running_dev_container_workspace() {
  if ! "${DOCKER[@]}" ps -q --filter "name=^${dev_name}$" | grep -q .; then
    return 1
  fi

  "${DOCKER[@]}" inspect "$dev_name" --format '{{ index .Config.Labels "dev.hva.workspace" }}' 2>/dev/null
}

ensure_dev_container() {
  local cws cimg img
  if [[ "${HVA_NEW_HARD_SESSION:-0}" == "1" ]] && "${DOCKER[@]}" inspect "$dev_name" &>/dev/null; then
    echo "recreating dev container for --new-hard" >&2
    "${DOCKER[@]}" rm -f "$dev_name" >/dev/null 2>&1 || true
  fi
  if "${DOCKER[@]}" inspect "$dev_name" &>/dev/null; then
    cws="$("${DOCKER[@]}" inspect "$dev_name" --format '{{ index .Config.Labels "dev.hva.workspace" }}')"
    cimg="$("${DOCKER[@]}" inspect "$dev_name" --format '{{.Image}}')"
    img="$("${DOCKER[@]}" image inspect "$DEV_IMAGE" --format '{{.Id}}')"
    if [[ "$cws" != "$WORKSPACE" || "$cimg" != "$img" ]]; then
      if [[ "$cws" != "$WORKSPACE" ]]; then
        echo "dev container workspace changed ($cws → $WORKSPACE); restarting" >&2
      else
        echo "dev image updated; restarting dev container" >&2
      fi
      "${DOCKER[@]}" rm -f "$dev_name" >/dev/null 2>&1 || true
    fi
  fi
  if ! "${DOCKER[@]}" ps -q --filter "name=^${dev_name}$" | grep -q .; then
    "${DOCKER[@]}" run -d \
      --name "$dev_name" \
      --label "dev.hva.workspace=$WORKSPACE" \
      "${start_docker_args[@]}" \
      "$DEV_IMAGE" sleep infinity >/dev/null
  fi
}

print_services() {
  if [[ "${HVA_SKIP_LLAMA:-0}" == "1" ]]; then
    return
  fi
  local svc="llama:$LLAMA_HOST_PORT"
  if [[ ",${HVA_MCP_ENABLED:-}," == *",searxng,"* ]]; then
    svc="$svc, searxng:${SEARXNG_HOST_PORT:-8888}"
  fi
  echo "services: $svc"
}

print_runtime_status() {
  local session_label="auto-continue"
  if [[ "${HVA_NEW_HARD_SESSION:-0}" == "1" ]]; then
    session_label="new-hard"
  elif [[ "$PI_SESSION_MODE" == "new" ]]; then
    session_label="new"
  fi
  echo "runtime: docker network: $HVA_DOCKER_NETWORK_MODE, session: $session_label"
}

ensure_searxng_server() {
  if [[ ",${HVA_MCP_ENABLED:-}," != *",searxng,"* ]]; then
    return
  fi
  "$HVA_ROOT/internals/run-hva-searxng.sh" start >/dev/null
}

declare -A _pi_lens_local_roots_seen=()
PI_LENS_LOCAL_SYMLINKS=()
declare -A _pi_lens_preexisting=()

# Snapshot ALL existing .pi-lens dirs before the session starts so the cleanup
# sweep never deletes user data that was there before hva ran.
while IFS= read -r -d '' _preexisting_lens; do
  _pi_lens_preexisting["$_preexisting_lens"]=1
done < <(find "$WORKSPACE" \
  \( -name .git -o -name node_modules -o -name target -o -name .hva-state \
     -o -name dist -o -name build -o -name out -o -name .next \
     -o -name __pycache__ -o -name .venv -o -name venv -o -name .turbo \) -prune -o \
  -type d -name '.pi-lens' -print0 2>/dev/null)

add_local_pi_lens_symlink() {
  local root="$1"
  local rel_path state_path link_path

  root="$(realpath "$root")"
  if [[ -n "${_pi_lens_local_roots_seen[$root]+x}" ]]; then
    return
  fi
  _pi_lens_local_roots_seen["$root"]=1

  if [[ "$root" == "$WORKSPACE" ]]; then
    state_path="$WORKSPACE_STATE_ROOT/pi-lens"
  else
    rel_path="${root#"$WORKSPACE"/}"
    state_path="$WORKSPACE_STATE_ROOT/pi-lens-subs/$rel_path"
  fi

  link_path="$root/.pi-lens"
  mkdir -p "$state_path"

  if [[ -e "$link_path" || -L "$link_path" ]]; then
    _pi_lens_preexisting["$link_path"]=1
    return
  fi

  ln -s "$state_path" "$link_path"
  PI_LENS_LOCAL_SYMLINKS+=("$link_path")
}

init_local_pi_lens_symlinks() {
  add_local_pi_lens_symlink "$WORKSPACE"

  while IFS= read -r -d '' manifest_path; do
    add_local_pi_lens_symlink "$(dirname "$manifest_path")"
  done < <(
    find "$WORKSPACE" \
      \( -name .git -o -name node_modules -o -name target -o -name .hva-state \
         -o -name dist -o -name build -o -name out -o -name .next \
         -o -name __pycache__ -o -name .venv -o -name venv -o -name .turbo \) -prune -o \
      \( -name package.json -o -name Cargo.toml -o -name pyproject.toml -o -name go.mod -o -name Gemfile -o -name composer.json -o -name pom.xml -o -name build.gradle -o -name build.gradle.kts \) \
      -print0 2>/dev/null
  )
}

prepare_local_pi_env() {
  local pi_dir="${PI_CODING_AGENT_DIR:-$HOME/.pi/agent}"

  "$HVA_ROOT/internals/overwrite-local-confs.sh" >/dev/null
  init_local_pi_lens_symlinks

  mkdir -p "$WORKSPACE_STATE_ROOT"
  export HVA_PI_EXTENSIONS_DIR="$HVA_ROOT/pi/extensions"
  export HVA_PI_SKILLS_SOURCE_DIR="$HVA_ROOT/skills"
  export HVA_PI_HVA_SKILLS_SOURCE_DIR="$HVA_ROOT/skills-hva"
  export HVA_PI_ACTIVE_SKILLS_DIR="$WORKSPACE_STATE_ROOT/pi-skills-active"
  export HVA_PI_SESSION_DIR="$pi_dir/sessions"
}

run_local_pi() {
  local -a run_args=()
  local prompt_text=""

  if [[ "$PI_SESSION_MODE" == "continue" ]]; then
    run_args+=(--continue)
  fi

  prepare_local_pi_env

  # shellcheck disable=SC1091
  source "$HVA_ROOT/internals/pi-runtime.sh"

  cd "$WORKSPACE"
  if [[ -n "$PROMPT_HOST_FILE" ]]; then
    prompt_text="$(cat "$PROMPT_HOST_FILE")"
    hva_run_pi "" "${run_args[@]}" --print "$prompt_text"
  else
    hva_run_pi "" "${run_args[@]}"
  fi
}

