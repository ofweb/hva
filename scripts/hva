if (( bash_reuse_running_container == 0 )); then
  if ! dev_container_is_reusable; then
    "${DOCKER[@]}" rm -f "$dev_name" >/dev/null 2>&1 || true
    ensure_dev_image
    ensure_dev_container
  fi
fi

remove_pi_lens_host_artifacts

if [[ "$MODE" == "loop" ]]; then
  loop_log="$LOOP_STATE_DIR/loop.log"
  mkdir -p "$LOOP_STATE_DIR"
  rm -f "$LOOP_STATE_DIR/status" "$LOOP_STATE_DIR/stop" "$loop_log"

  # strip tty/stdin flags — loop runs detached
  loop_exec_args=()
  for _arg in "${exec_args[@]}"; do
    case "$_arg" in -i|-it|-t) continue ;; esac
    loop_exec_args+=("$_arg")
  done

  # snapshot task counts before starting
  pending_start=0; done_start=0
  if [[ -f "$LOOP_TASK_FILE" ]]; then
    pending_start="$(awk '/^[[:space:]]*[-*+][[:space:]]+\[[[:space:]]*\][[:space:]]+/ && $0 !~ /[[:space:]]+BLOCKED:/ { count += 1 } END { print count + 0 }' "$LOOP_TASK_FILE" 2>/dev/null || true)"
    pending_start="${pending_start:-0}"
    done_start="$(grep -Eic '^[[:space:]]*[-*+][[:space:]]+\[[xX]\][[:space:]]+' "$LOOP_TASK_FILE" 2>/dev/null || true)"
    done_start="${done_start:-0}"
  fi

  "${DOCKER[@]}" exec "${loop_exec_args[@]}" "$dev_name" "$@" >"$loop_log" 2>&1 &
  loop_pid=$!

  cleanup_loop() {
    echo
    echo "stopping (finishing current iteration)..."
    : > "$LOOP_STATE_DIR/stop"
    wait "$loop_pid" 2>/dev/null || true
    echo "stopped. log: $loop_log"
    exit 0
  }
  trap cleanup_loop INT TERM

  read_status_field() {
    local field="$1"
    grep "^${field}:" "$LOOP_STATE_DIR/status" 2>/dev/null \
      | sed "s/^${field}:[[:space:]]*//" | head -1
  }

  elapsed_fmt() {
    local s="${1:-0}"
    printf '%dm%ds' "$(( s / 60 ))" "$(( s % 60 ))"
  }

  echo "tasks:  ${pending_start} pending, ${done_start} done"
  echo "log:    $loop_log"
  echo "stop:   Ctrl+C  or  hva --loop-stop"
  echo

  last_key=""; waiting_shown=0
  while kill -0 "$loop_pid" 2>/dev/null; do
    if [[ ! -f "$LOOP_STATE_DIR/status" ]]; then
      if (( waiting_shown == 0 )); then
        echo "starting..."; waiting_shown=1
      fi
      sleep 1; continue
    fi

    _state="$(read_status_field state)"
    _phase="$(read_status_field phase)"
    _iter="$(read_status_field iteration)"
    _target="$(read_status_field current_target)"
    _pending="$(read_status_field pending_tasks)"
    _done="$(read_status_field done_tasks)"
    _key="${_iter}:${_phase}:${_state}"

    if [[ "$_key" != "$last_key" && -n "$_iter" && "$_iter" != "0" ]]; then
      _elapsed="$(read_status_field elapsed_seconds)"
      _context=""
      if [[ "${_pending:-0}" == "0" && ( "$_phase" == "review" || "$_phase" == "improve" ) ]]; then
        _context=" — all tasks done"
      fi
      echo "[$(elapsed_fmt "${_elapsed}")] iter ${_iter} — ${_phase}: ${_target:-…} (done: ${_done:-0}, pending: ${_pending:-0})${_context}"
      last_key="$_key"
    fi

    if [[ "$_state" == "finished" || "$_state" == "stopped" ]]; then break; fi
    sleep 2
  done

  wait "$loop_pid" 2>/dev/null || true
  trap - INT TERM

  echo
  if [[ -f "$LOOP_STATE_DIR/status" ]]; then
    _fstate="$(read_status_field state)"
    _fmsg="$(read_status_field message)"
    _fiter="$(read_status_field iteration)"
    _fpending="$(read_status_field pending_tasks)"
    _fdone="$(read_status_field done_tasks)"
    _felapsed="$(read_status_field elapsed_seconds)"
    echo "=== loop ${_fstate:-done} ($(elapsed_fmt "${_felapsed}")) ==="
    echo "iterations: ${_fiter:-0}  |  done: ${_fdone:-0}  |  pending: ${_fpending:-0}"
    [[ -n "$_fmsg" ]] && echo "${_fmsg}"
    echo "log: $loop_log"
  fi
else
  "${DOCKER[@]}" exec "${exec_args[@]}" "$dev_name" "$@"
fi
