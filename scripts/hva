      if [[ "$WORKSPACE" == "$bash_running_workspace" ]]; then
        container_workdir="/workspace"
      elif [[ "$WORKSPACE" == "$bash_running_workspace"/* ]]; then
        rel_bash_workdir="${WORKSPACE#"$bash_running_workspace"/}"
        container_workdir="/workspace/$rel_bash_workdir"
      else
        echo "reusing running dev container workspace: $bash_running_workspace" >&2
        echo "requested path is not mounted there, opening /workspace instead" >&2
      fi
    fi
  fi
fi

