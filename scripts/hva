#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"
HVA_ROOT="${HVA_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd -P)}"

usage() {
  cat <<EOF
Usage:
  hva                          start/reuse llama, enter workspace, open Nanocoder
  hva --bash                   enter workspace shell; does not wait for llama
  hva --prompt TEXT            run one-shot Nanocoder prompt inside dev container
  hva --prompt-file FILE       run one-shot Nanocoder prompt from file
  hva --diff-review REV        review git diff from REV..HEAD

  hva --diff-review-branch BRANCH
                               review git diff from merge-base(BRANCH, HEAD)..HEAD

  hva --diff-review-main       review git diff from merge-base(main/master, HEAD)..HEAD
  hva --diff-review-staged     review staged git diff
  hva --diff-review-unstaged   review unstaged git diff
  hva --diff-review-all        review tracked + untracked git diff without touching real index
  hva --stop                   stop the llama server container
  hva --daemon                 start llama server as background daemon
  hva --healthcheck            compact llama health verdict
  hva --llama-cpp-update       update pinned llama.cpp image digest, then pull it
  hva --llama-cpp-logs-full    print full llama server container logs
  hva --build-docker-prison    build dev image if missing/outdated (--force to rebuild anyway)
  hva --check-versions         check pinned vs latest upstream versions
EOF
}

MODE="start"
PROMPT_TEXT=""
PROMPT_FILE=""
DIFF_REVIEW_MODE=""
DIFF_REVIEW_TARGET=""
case "${1:-}" in

  --stop)    MODE="stop";   shift ;;
  --daemon)  MODE="daemon"; shift ;;
  --bash)    MODE="bash";   shift ;;
  --prompt)
    [[ $# -ge 2 ]] || { echo "--prompt requires text" >&2; exit 1; }
    MODE="prompt"
    PROMPT_TEXT="$2"
    shift 2
    ;;
  --prompt-file)
    [[ $# -ge 2 ]] || { echo "--prompt-file requires a file path" >&2; exit 1; }
    MODE="prompt"
    PROMPT_FILE="$2"
    shift 2
    ;;
  --diff-review)
    [[ $# -ge 2 ]] || { echo "--diff-review requires a revision" >&2; exit 1; }
    MODE="diff-review"
    DIFF_REVIEW_MODE="commit"
    DIFF_REVIEW_TARGET="$2"
    shift 2
    ;;
  --diff-review-branch)
    [[ $# -ge 2 ]] || { echo "--diff-review-branch requires a branch or revision" >&2; exit 1; }
    MODE="diff-review"
    DIFF_REVIEW_MODE="branch"
    DIFF_REVIEW_TARGET="$2"
    shift 2
    ;;
  --diff-review-main)
    MODE="diff-review"
    DIFF_REVIEW_MODE="main"
    shift
    ;;
  --diff-review-staged)
    MODE="diff-review"
    DIFF_REVIEW_MODE="staged"
    shift
    ;;
  --diff-review-unstaged)
    MODE="diff-review"
    DIFF_REVIEW_MODE="unstaged"
    shift
    ;;
  --diff-review-all)
    MODE="diff-review"
    DIFF_REVIEW_MODE="all"
    shift
    ;;
  --healthcheck)         exec "$HVA_ROOT/internals/healthcheck.sh" "${@:2}" ;;
  --llama-cpp-update)    exec "$HVA_ROOT/internals/llama-cpp-update.sh" "${@:2}" ;;
  --build-docker-prison)  exec "$HVA_ROOT/internals/build-docker-prison.sh" "${@:2}" ;;
  --check-versions)       exec "$HVA_ROOT/internals/check-versions.sh" "${@:2}" ;;
  --llama-cpp-logs-full)  exec "$HVA_ROOT/internals/run-hva-llama-cpp.sh" logs ;;
  -h|--help|help) usage; exit 0 ;;
  --*)
    echo "unknown option: $1" >&2
    usage
    exit 1
    ;;
esac

if [[ "$MODE" == "stop" ]]; then
  exec "$HVA_ROOT/internals/run-hva-llama-cpp.sh" stop
fi

source "$SCRIPT_DIR/../env/env-source.sh"
source "$SCRIPT_DIR/../env/env-validate.sh"
env_validate_required

if [[ "$MODE" == "daemon" ]]; then
  exec "$HVA_ROOT/internals/run-hva-llama-cpp.sh" daemon
fi

DEV_IMAGE="hva-safeprison"
DEV_USER="dev"
HVA_MODE="nanocoder"
PROMPT_HOST_FILE=""
PROMPT_CONTAINER_FILE="/tmp/hva-prompt.txt"
PROMPT_FILE_TEMP=0

if [[ "$MODE" == "prompt" || "$MODE" == "diff-review" ]]; then
  HVA_MODE="nanocoder"
fi

if [[ "$MODE" == "bash" ]]; then
  HVA_MODE="bash"
  HVA_WAIT_LLAMA="${HVA_WAIT_LLAMA:-0}"
fi

WORKSPACE="$PWD"
if [[ $# -gt 0 && -d "$1" ]]; then
  WORKSPACE="$1"
  shift
fi
WORKSPACE="$(realpath "$WORKSPACE")"

if [[ ! -d "$WORKSPACE" ]]; then
  echo "workspace does not exist: $WORKSPACE" >&2
  exit 1
fi

case "$WORKSPACE" in
  /tmp|/var/tmp|/dev/shm)
    if [[ "${HVA_ALLOW_SYSTEM_TMP_WORKSPACE:-0}" != "1" ]]; then
      echo "refusing to use system temp root as workspace: $WORKSPACE" >&2
      echo "cd into a project directory, pass one explicitly, or set HVA_ALLOW_SYSTEM_TMP_WORKSPACE=1." >&2
      exit 1
    fi
    ;;
esac

cleanup() {
  if [[ "$PROMPT_FILE_TEMP" == "1" && -n "$PROMPT_HOST_FILE" && -f "$PROMPT_HOST_FILE" ]]; then
    rm -f "$PROMPT_HOST_FILE"
  fi
}

trap cleanup EXIT

write_prompt_text_file() {
  local text="$1"
  PROMPT_HOST_FILE="$(mktemp "${TMPDIR:-/tmp}/hva-prompt.XXXXXX")"
  PROMPT_FILE_TEMP=1
  printf '%s' "$text" > "$PROMPT_HOST_FILE"
}

validate_diff_review_size() {
  local label="$1"
  local diff_content="$2"
  local diff_bytes diff_lines max_bytes

  diff_bytes="$(printf '%s' "$diff_content" | wc -c | tr -d ' ')"
  diff_lines="$(printf '%s' "$diff_content" | wc -l | tr -d ' ')"
  max_bytes=$((LLAMA_CONTEXT_SIZE * 3))

  if (( diff_bytes > max_bytes )); then
    echo "diff too large for review: $label" >&2
    echo "diff bytes: $diff_bytes" >&2
    echo "diff lines: $diff_lines" >&2
    echo "soft limit from LLAMA_CONTEXT_SIZE=$LLAMA_CONTEXT_SIZE: $max_bytes bytes" >&2
    echo "try a narrower diff review target" >&2
    echo "  hva --diff-review-staged" >&2
    echo "  hva --diff-review-unstaged" >&2
    echo "  hva --diff-review <rev>" >&2
    echo "  hva --diff-review-branch <branch>" >&2
    exit 1
  fi
}

prepare_diff_review_prompt() {
  local diff_content label

  case "$DIFF_REVIEW_MODE" in
    unstaged) label="unstaged changes" ;;
    staged)   label="staged changes" ;;
    commit)   label="diff from $DIFF_REVIEW_TARGET to HEAD" ;;
    branch)   label="diff from merge-base($DIFF_REVIEW_TARGET, HEAD) to HEAD" ;;
    main)     label="diff from merge-base(main/master, HEAD) to HEAD" ;;
    all)      label="all changes" ;;
    *)        echo "unknown diff review mode: $DIFF_REVIEW_MODE" >&2; exit 1 ;;
  esac

  diff_content="$("$HVA_ROOT/internals/git-diff.sh" "$DIFF_REVIEW_MODE" "$DIFF_REVIEW_TARGET" "$WORKSPACE")"

  if [[ -z "$diff_content" ]]; then
    echo "no $label"
    exit 0
  fi

  validate_diff_review_size "$label" "$diff_content"

  PROMPT_HOST_FILE="$(mktemp "${TMPDIR:-/tmp}/hva-review.XXXXXX")"
  PROMPT_FILE_TEMP=1
  {
    cat <<EOF
Read the entire codebase first, then review this diff.

Focus on: bugs, broken logic, inconsistencies with the rest of the project, missing wiring. Not style.

Review target: $label

Diff:
EOF
    printf '```diff\n'
    printf '%s\n' "$diff_content"
    printf '```\n'
  } > "$PROMPT_HOST_FILE"
}

prepare_prompt_mode() {
  case "$MODE" in
    prompt)
      if [[ -n "$PROMPT_FILE" ]]; then
        if [[ ! -f "$PROMPT_FILE" ]]; then
          echo "prompt file does not exist: $PROMPT_FILE" >&2
          exit 1
        fi
        PROMPT_HOST_FILE="$(realpath "$PROMPT_FILE")"
      else
        write_prompt_text_file "$PROMPT_TEXT"
      fi
      ;;
    diff-review)
      prepare_diff_review_prompt
      ;;
    *)
      return
      ;;
  esac

}

prepare_prompt_mode

source "$SCRIPT_DIR/../internals/docker.sh"

ensure_llama_server() {
  if [[ "${HVA_SKIP_LLAMA:-0}" == "1" ]]; then
    echo "skipping llama server startup because HVA_SKIP_LLAMA=1"
    return
  fi

  local action="daemon"
  if [[ "${HVA_RESTART_LLAMA:-0}" == "1" ]]; then
    action="restart"
  fi

  "$HVA_ROOT/internals/run-hva-llama-cpp.sh" "$action"
}

print_llama_startup_failure() {
  local url="$1"
  local timeout="$2"
  local log_tail="${HVA_LLAMA_LOG_TAIL:-120}"

  {
    echo
    echo "llama server did not become ready within ${timeout}s."
    echo "URL: $url"
    echo "Container: $LLAMA_CONTAINER"
    echo
    echo "Recent llama logs:"
  } >&2

  if ! "${DOCKER[@]}" logs --tail "$log_tail" "$LLAMA_CONTAINER" >&2; then
    echo "could not read logs for container: $LLAMA_CONTAINER" >&2
  fi

  {
    echo
    echo "Try:"
    echo "  $HVA_ROOT/internals/run-hva-llama-cpp.sh status"
    echo "  ${DOCKER[*]} logs -f $LLAMA_CONTAINER"
    echo "  hva --stop"
  } >&2
}

wait_for_llama_server() {
  if [[ "${HVA_SKIP_LLAMA:-0}" == "1" ]]; then
    return
  fi

  if [[ "${HVA_WAIT_LLAMA:-1}" == "0" ]]; then
    echo "skipping llama readiness wait because HVA_WAIT_LLAMA=0"
    return
  fi

  local url="http://127.0.0.1:$LLAMA_HOST_PORT/v1/models"
  local timeout="${HVA_LLAMA_WAIT_TIMEOUT:-40}"
  local waited=0

  if ! command -v curl >/dev/null 2>&1; then
    echo "curl is not installed; skipping llama readiness check" >&2
    return
  fi

  until curl -fsS --max-time 2 "$url" >/dev/null 2>&1; do
    if (( waited >= timeout )); then
      print_llama_startup_failure "$url" "$timeout"
      exit 1
    fi
    if (( waited == 0 )); then
      echo "waiting for llama server: $url"
    fi
    sleep 2
    waited=$((waited + 2))
  done

  if (( waited > 0 )); then
    echo "llama server ready after ${waited}s"
  fi
}

ensure_dev_image() {
  local current_hash image_hash

  current_hash="$(
    {
      cd "$HVA_ROOT/docker"
      find . -type f -print0 | sort -z | xargs -0 sha256sum
      printf 'HVA_CSHARP=%s\n' "$HVA_CSHARP"
    } | sha256sum | awk '{print $1}'
  )"

  image_hash="$("${DOCKER[@]}" image inspect "$DEV_IMAGE" --format '{{ index .Config.Labels "dev.hva.source-hash" }}' 2>/dev/null || true)"

  if [[ -z "$image_hash" || "${HVA_REBUILD:-0}" == "1" ]]; then
    IMAGE_NAME="$DEV_IMAGE" "$HVA_ROOT/internals/build-docker-prison.sh"
    return
  fi

  if [[ "$image_hash" != "$current_hash" ]]; then
    echo "dev image is out of date: $DEV_IMAGE" >&2
    echo "run: hva --build-docker-prison" >&2
    exit 1
  fi
}

workspace_has_agent_file() {
  [[ -e "$WORKSPACE/AGENTS.md" ]]
}

had_agent_file=0
copied_agent_file=0
if workspace_has_agent_file; then
  had_agent_file=1
fi

ensure_workspace_agents() {
  if [[ "${HVA_COPY_AGENTS:-1}" == "0" ]]; then
    return
  fi

  local template="$HVA_ROOT/nanocoder/example-agent.md"

  if (( had_agent_file == 1 )); then
    return
  fi

  if [[ ! -f "$template" ]]; then
    echo "agent template missing: $template" >&2
    exit 1
  fi

  if ! install -m 0644 "$template" "$WORKSPACE/AGENTS.md"; then
    echo "failed to copy AGENTS.md from template: $template" >&2
    exit 1
  fi
  copied_agent_file=1
}

ensure_llama_server
wait_for_llama_server
ensure_dev_image
ensure_workspace_agents

STATE_ROOT="$HVA_ROOT/.hva-state"
mkdir -p "$STATE_ROOT"
STATE_ROOT="$(cd "$STATE_ROOT" && pwd -P)"

CARGO_REGISTRY_CACHE="$STATE_ROOT/cargo/registry"
CARGO_GIT_CACHE="$STATE_ROOT/cargo/git"
UV_CACHE="$STATE_ROOT/uv"
NPM_CACHE="$STATE_ROOT/npm"
MCP_PYPI_CACHE="$STATE_ROOT/mcp-pypi"
RUST_DOCS_CACHE="$STATE_ROOT/rust-docs-mcp"
GIT_FILE_MASK="$STATE_ROOT/empty-git-file"
NANOCODER_CONFIG_ROOT="$STATE_ROOT/nanocoder-configs"
NANOCODER_DATA_ROOT="$STATE_ROOT/nanocoder-data"

mkdir -p \
  "$CARGO_REGISTRY_CACHE" \
  "$CARGO_GIT_CACHE" \
  "$UV_CACHE" \
  "$NPM_CACHE" \
  "$MCP_PYPI_CACHE" \
  "$RUST_DOCS_CACHE" \
  "$NANOCODER_CONFIG_ROOT" \
  "$NANOCODER_DATA_ROOT"
: > "$GIT_FILE_MASK"

if [[ "${HVA_LOAD_MCP_ENV:-1}" == "1" && -f "$HOME/.config/nanocoder/mcp.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$HOME/.config/nanocoder/mcp.env"
  set +a
fi

if [[ -z "${GITHUB_TOKEN-}" && -n "${GITHUB_PERSONAL_ACCESS_TOKEN-}" ]]; then
  export GITHUB_TOKEN="$GITHUB_PERSONAL_ACCESS_TOKEN"
fi

if [[ -z "${GITHUB_PERSONAL_ACCESS_TOKEN-}" && -n "${GITHUB_TOKEN-}" ]]; then
  export GITHUB_PERSONAL_ACCESS_TOKEN="$GITHUB_TOKEN"
fi

workspace_base="$(basename "$WORKSPACE")"
safe_workspace_name="$(printf '%s' "$workspace_base" | tr -c 'A-Za-z0-9_.-' '-')"
if [[ -z "$safe_workspace_name" ]]; then
  safe_workspace_name="workspace"
fi

workspace_hash="$(printf '%s' "$WORKSPACE" | sha256sum | awk '{print substr($1, 1, 16)}')"
NANOCODER_CONFIG_CACHE="$NANOCODER_CONFIG_ROOT/shared"
NANOCODER_DATA_CACHE="$NANOCODER_DATA_ROOT/$safe_workspace_name-$workspace_hash"
mkdir -p "$NANOCODER_DATA_CACHE"

prepare_nanocoder_config() {
  local preferences_source="$HVA_ROOT/nanocoder/nanocoder-preferences.sample.json"
  if [[ -f "$HVA_ROOT/nanocoder/nanocoder-preferences.json" ]]; then
    preferences_source="$HVA_ROOT/nanocoder/nanocoder-preferences.json"
  fi

  mkdir -p "$NANOCODER_CONFIG_CACHE/bin" "$NANOCODER_CONFIG_CACHE/logs"

  install -m 0644 "$HVA_ROOT/nanocoder/.mcp.json" "$NANOCODER_CONFIG_CACHE/.mcp.json"
  if [[ ! -e "$NANOCODER_CONFIG_CACHE/nanocoder-preferences.json" ]]; then
    install -m 0644 "$preferences_source" "$NANOCODER_CONFIG_CACHE/nanocoder-preferences.json"
  fi
  for helper in "$HVA_ROOT"/nanocoder/bin/*; do
    helper_name="$(basename "$helper")"
    helper_target="$NANOCODER_CONFIG_CACHE/bin/$helper_name"
    ln -sfn "/hva/nanocoder/bin/$helper_name" "$helper_target"
  done

  "$HVA_ROOT/nanocoder/render-lsp-mask.sh" "$NANOCODER_CONFIG_CACHE/bin/lsp-mask" >/dev/null
}

dev_name="hva-dev-$safe_workspace_name-$$"
prepare_nanocoder_config

"$HVA_ROOT/nanocoder/render-agents-config.sh" "$NANOCODER_CONFIG_CACHE/agents.config.json" "http://host.docker.internal:$LLAMA_HOST_PORT/v1" >/dev/null

stdio_args=(-i)
if [[ -t 0 && -t 1 ]]; then
  stdio_args=(-it)
fi

docker_args=(
  --rm
  "${stdio_args[@]}"
  --init
  --name "$dev_name"
  --add-host host.docker.internal:host-gateway
  -v "$WORKSPACE:/workspace"
  -v "$CARGO_REGISTRY_CACHE:/home/$DEV_USER/.cargo/registry"
  -v "$CARGO_GIT_CACHE:/home/$DEV_USER/.cargo/git"
  -v "$UV_CACHE:/home/$DEV_USER/.cache/uv"
  -v "$NPM_CACHE:/home/$DEV_USER/.npm"
  -v "$MCP_PYPI_CACHE:/home/$DEV_USER/.cache/mcp-pypi"
  -v "$RUST_DOCS_CACHE:/home/$DEV_USER/.cache/rust-docs-mcp"
  -v "$NANOCODER_CONFIG_CACHE:/home/$DEV_USER/.config/nanocoder"
  -v "$NANOCODER_DATA_CACHE:/home/$DEV_USER/.local/share/nanocoder"
  -v "$HVA_ROOT/nanocoder:/hva/nanocoder:ro"
  -v "$HVA_ROOT/docker/versions.env:/hva/docker/versions.env:ro"
  -v "$HVA_ROOT/internals/docker.sh:/hva/internals/docker.sh:ro"
  -v "$HVA_ROOT/docker/nanocoder-wrapper:/usr/local/bin/nanocoder:ro"
  -w /workspace
  -e CARGO_NET_GIT_FETCH_WITH_CLI=true
  -e RUST_BACKTRACE=1
  -e NANOCODER_CONFIG_DIR="/home/$DEV_USER/.config/nanocoder"
  -e NANOCODER_DATA_DIR="/home/$DEV_USER/.local/share/nanocoder"
  -e NANOCODER_DEVELOPMENT_MODE=yolo
  -e NANOCODER_TRUST_CONTAINER=1
  -e NANOCODER_CONTEXT_LIMIT="$LLAMA_CONTEXT_SIZE"
)

passed_secret_envs=()
for env_name in \
  HVA_MCP_ENABLED \
  HVA_MCP_DISABLED \
  HVA_LSP_ENABLED \
  HVA_LSP_DISABLED \
  GITHUB_PERSONAL_ACCESS_TOKEN \
  GITHUB_TOKEN \
  BRAVE_API_KEY \
  HF_TOKEN \
  HUGGING_FACE_HUB_TOKEN; do
  if [[ -n "${!env_name-}" ]]; then
    case "$env_name" in
      BRAVE_API_KEY)
        [[ ",$HVA_MCP_ENABLED," == *",brave-search,"* ]] || continue
        ;;
      GITHUB_PERSONAL_ACCESS_TOKEN|GITHUB_TOKEN)
        if [[ ",$HVA_MCP_ENABLED," != *",github,"* && ",$HVA_MCP_ENABLED," != *",rust-docs,"* ]]; then
          continue
        fi
        ;;
    esac
    docker_args+=(-e "$env_name")
    case "$env_name" in
      GITHUB_PERSONAL_ACCESS_TOKEN|BRAVE_API_KEY|HF_TOKEN|HUGGING_FACE_HUB_TOKEN)
        passed_secret_envs+=("$env_name")
        ;;
    esac
  fi
done

if [[ "${HVA_UNSAFE:-0}" == "1" ]]; then
  docker_args+=(
    --cap-add SYS_PTRACE
    --security-opt seccomp=unconfined
  )
fi

if [[ -S /var/run/docker.sock ]]; then
  docker_sock_gid="$(stat -c '%g' /var/run/docker.sock)"
  if [[ "${HVA_UNSAFE:-0}" == "1" ]]; then
    docker_args+=(
      -v /var/run/docker.sock:/var/run/docker.sock
      --group-add "$docker_sock_gid"
    )
  fi
fi

if [[ "${HVA_MOUNT_GITCONFIG:-0}" == "1" && -f "$HOME/.gitconfig" ]]; then
  docker_args+=(-v "$HOME/.gitconfig:/home/$DEV_USER/.gitconfig:ro")
fi

if [[ "${HVA_MOUNT_NVIM:-0}" == "1" && -d "$HOME/.config/nvim" ]]; then
  docker_args+=(-v "$HOME/.config/nvim:/home/$DEV_USER/.config/nvim:ro")
fi

if [[ "${HVA_MOUNT_SSH:-0}" == "1" && -d "$HOME/.ssh" ]]; then
  docker_args+=(-v "$HOME/.ssh:/home/$DEV_USER/.ssh:ro")
fi

while IFS= read -r -d '' git_path; do
  rel_path="${git_path#"$WORKSPACE"/}"
  if [[ "$git_path" == "$WORKSPACE" ]]; then
    rel_path="."
  fi
  dest="/workspace/$rel_path"

  if [[ -d "$git_path" ]]; then
    docker_args+=(--tmpfs "$dest:rw,noexec,nosuid,nodev,size=64k")
  elif [[ -f "$git_path" ]]; then
    docker_args+=(--mount "type=bind,source=$GIT_FILE_MASK,target=$dest,readonly")
  fi
done < <(find "$WORKSPACE" -name .git -prune -print0 2>/dev/null)

run_nanocoder_init_if_needed() {
  if [[ "${HVA_INIT_WORKSPACE:-0}" != "1" ]]; then
    return
  fi

  if [[ "$HVA_MODE" != "nanocoder" || $# -ne 0 ]]; then
    return
  fi

  if [[ -d "$WORKSPACE/.nanocoder" ]]; then
    return
  fi

  echo "initializing Nanocoder workspace with /init"
  init_docker_args=()
  for ((i = 0; i < ${#docker_args[@]}; i++)); do
    if [[ "${docker_args[$i]}" == "-e" && "${docker_args[$((i + 1))]-}" == NANOCODER_MCPSERVERS=* ]]; then
      i=$((i + 1))
      continue
    fi
    init_docker_args+=("${docker_args[$i]}")
  done
  init_docker_args+=(-e 'NANOCODER_MCPSERVERS={"mcpServers":{}}')

  if ! "${DOCKER[@]}" run "${init_docker_args[@]}" "$DEV_IMAGE" nanocoder run "/init"; then
    echo "warning: nanocoder /init failed; continuing into container" >&2
  fi
}

if [[ "$HVA_MODE" == "nanocoder" && $# -eq 0 && -z "$PROMPT_HOST_FILE" ]]; then
  run_nanocoder_init_if_needed "$@"
fi

if [[ -n "$PROMPT_HOST_FILE" ]]; then
  docker_args+=(--mount "type=bind,source=$PROMPT_HOST_FILE,target=$PROMPT_CONTAINER_FILE,readonly")
fi

if [[ $# -eq 0 ]]; then
  case "$HVA_MODE" in
    bash)
      set -- bash
      ;;
    nanocoder)
      if [[ -n "$PROMPT_HOST_FILE" ]]; then
        set -- bash -lc 'nanocoder run "$(cat "$1")"' bash "$PROMPT_CONTAINER_FILE"
      else
        set -- bash -lc 'nanocoder; exec bash'
      fi
      ;;
    *)
      echo "unknown HVA_MODE: $HVA_MODE" >&2
      exit 1
      ;;
  esac
fi

echo "workspace: $WORKSPACE ($LLAMA_MODEL_ALIAS · $LLAMA_MODEL)"
if (( copied_agent_file == 1 )); then
  echo "AGENTS.md: copied from $HVA_ROOT/nanocoder/example-agent.md"
elif (( had_agent_file == 1 )); then
  agents_template="$HVA_ROOT/nanocoder/example-agent.md"
  if [[ -f "$agents_template" && -f "$WORKSPACE/AGENTS.md" ]] && command -v sha256sum >/dev/null 2>&1; then
    template_agents_sha="$(sha256sum "$agents_template" | awk '{print $1}')"
    project_agents_sha="$(sha256sum "$WORKSPACE/AGENTS.md" | awk '{print $1}')"
    if [[ "$template_agents_sha" == "$project_agents_sha" ]]; then
      echo "AGENTS.md: project matches shared template"
    else
      echo "AGENTS.md: project file differs from shared template"
      echo "  project sha256: $project_agents_sha"
      echo "  shared sha256:  $template_agents_sha"
      echo "  update command: cp \"$agents_template\" \"$WORKSPACE/AGENTS.md\""
    fi
  else
    echo "AGENTS.md: project file exists"
  fi
else
  if [[ "${HVA_COPY_AGENTS:-1}" == "0" ]]; then
    echo "AGENTS.md: template copy disabled"
  else
    agents_template="$HVA_ROOT/nanocoder/example-agent.md"
    echo "AGENTS.md: template missing: $agents_template"
  fi
fi
if (( ${#passed_secret_envs[@]} > 0 )); then
  echo "secrets: ${passed_secret_envs[*]}"
fi
if [[ -n "$PROMPT_HOST_FILE" ]]; then
  echo "prompt mode: $MODE"
fi
if [[ "${HVA_UNSAFE:-0}" == "1" ]]; then
  echo "unsafe mode: SYS_PTRACE, seccomp=unconfined, docker socket"
fi

"${DOCKER[@]}" run "${docker_args[@]}" "$DEV_IMAGE" "$@"
