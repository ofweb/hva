{
  "mcpServers": {
    "brave-search": {
      "enabled": false,
      "transport": "stdio",
      "command": "${HOME}/.config/nanocoder/bin/brave-search-mcp-quiet",
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY:-}"
      },
      "description": "Fallback web search MCP server.",
      "tags": [
        "search",
        "web",
        "fallback"
      ],
      "timeout": 60000
    },
    "github": {
      "enabled": false,
      "transport": "stdio",
      "command": "${HOME}/.config/nanocoder/bin/github-mcp-quiet",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN:-}",
        "NANOCODER_GITHUB_MCP_LOG": "${HOME}/.config/nanocoder/logs/github-mcp.log"
      },
      "description": "Official GitHub MCP server, local Docker, read-only repository/code browsing.",
      "tags": [
        "github",
        "code",
        "repos"
      ],
      "timeout": 60000
    },
    "ripgrep": {
      "enabled": true,
      "transport": "stdio",
      "command": "${HOME}/.config/nanocoder/bin/mcp-ripgrep-quiet",
      "description": "Local workspace search powered by ripgrep.",
      "tags": [
        "local",
        "search",
        "code"
      ],
      "timeout": 60000
    },
    "rust-docs": {
      "enabled": true,
      "transport": "stdio",
      "command": "${HOME}/.cargo/bin/rust-docs-mcp",
      "env": {
        "RUST_DOCS_MCP_CACHE_DIR": "${HOME}/.cache/rust-docs-mcp",
        "GITHUB_TOKEN": "${GITHUB_TOKEN:-}"
      },
      "description": "Rust crate docs, source, dependency trees, and local crate cache.",
      "tags": [
        "rust",
        "cargo",
        "docs",
        "source"
      ],
      "timeout": 120000
    },
    "pypi": {
      "enabled": false,
      "transport": "stdio",
      "command": "${HOME}/.config/nanocoder/bin/mcp-pypi-quiet",
      "env": {
        "MCP_PYPI_CACHE_DIR": "${HOME}/.cache/mcp-pypi",
        "NANOCODER_MCP_PYPI_LOG": "${HOME}/.config/nanocoder/logs/mcp-pypi.log"
      },
      "description": "PyPI package search, package metadata, requirements checks, and package safety context.",
      "tags": [
        "python",
        "pypi",
        "packages"
      ],
      "timeout": 120000
    },
    "npm-search": {
      "enabled": false,
      "transport": "stdio",
      "command": "${HOME}/.config/nanocoder/bin/npm-search-mcp-quiet",
      "description": "npm package registry search.",
      "tags": [
        "node",
        "npm",
        "packages"
      ],
      "timeout": 60000
    },
    "duckduckgo-search": {
      "enabled": true,
      "transport": "stdio",
      "command": "${HOME}/.config/nanocoder/bin/duckduckgo-mcp-quiet",
      "description": "Free web search fallback through DuckDuckGo.",
      "tags": [
        "search",
        "web",
        "fallback"
      ],
      "timeout": 60000
    }
  }
}
