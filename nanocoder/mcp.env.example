# Optional bash-style secrets file.
# Skip this file if your shell already exports these env vars.
# hva loads ~/.config/nanocoder/mcp.env when it exists, then passes the
# secret env names into the container without printing values.
#
# Use a fine-grained GitHub PAT with the minimum repository access you need.
# export GITHUB_PERSONAL_ACCESS_TOKEN="github_pat_or_ghp_token_here"
# Optional GitHub token alias. hva mirrors this to GITHUB_PERSONAL_ACCESS_TOKEN.
# export GITHUB_TOKEN="github_pat_or_ghp_token_here"
#
# Optional fallback web search MCP. Used only when brave-search is enabled.
# export BRAVE_API_KEY="brave_api_key_here"
#
# Optional passthrough tokens for tools you run manually inside the container.
# export HF_TOKEN="hf_token_here"
# export HUGGING_FACE_HUB_TOKEN="hf_token_here"
