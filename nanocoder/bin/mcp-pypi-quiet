#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
HVA_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/../.." && pwd -P)"

source "$HVA_ROOT/docker/versions.env"

log_file="${NANOCODER_MCP_PYPI_LOG:-$HOME/.config/nanocoder/logs/mcp-pypi.log}"
mkdir -p "$(dirname "$log_file")"

exec uvx --from "mcp-pypi==${HVA_V_MCP_PYPI_VERSION}" mcp-pypi stdio 2>>"$log_file"
