#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
HVA_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/../.." && pwd -P)"

source "$HVA_ROOT/docker/versions.env"

log_file="${NANOCODER_MCP_NPM_SEARCH_LOG:-$HOME/.config/nanocoder/logs/npm-search-mcp.log}"
mkdir -p "$(dirname "$log_file")"

exec npx -y "npm-search-mcp-server@${HVA_V_NPM_SEARCH_MCP_VERSION}" 2>>"$log_file"
