#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
HVA_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/../.." && pwd -P)"

source "$HVA_ROOT/docker/versions.env"

log_file="${NANOCODER_MCP_DUCKDUCKGO_LOG:-$HOME/.config/nanocoder/logs/duckduckgo-mcp.log}"
mkdir -p "$(dirname "$log_file")"

exec npx -y "duckduckgo-mcp-server@${HVA_V_DUCKDUCKGO_MCP_VERSION}" 2>>"$log_file"
