#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
HVA_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/../.." && pwd -P)"

source "$HVA_ROOT/docker/versions.env"

log_file="${NANOCODER_MCP_BRAVE_SEARCH_LOG:-$HOME/.config/nanocoder/logs/brave-search-mcp.log}"
mkdir -p "$(dirname "$log_file")"

exec npx -y "@brave/brave-search-mcp-server@${HVA_V_BRAVE_SEARCH_MCP_VERSION}" --transport stdio 2>>"$log_file"
