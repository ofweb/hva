#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
HVA_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/../.." && pwd -P)"

source "$HVA_ROOT/docker/versions.env"

log_file="${NANOCODER_MCP_RIPGREP_LOG:-$HOME/.config/nanocoder/logs/mcp-ripgrep.log}"
mkdir -p "$(dirname "$log_file")"

exec npx -y "mcp-ripgrep@${HVA_V_MCP_RIPGREP_VERSION}" 2>>"$log_file"
